# --- VCS / IDE / agent metadata ---

.git
.gitignore
.gitattributes
.idea
.vscode
.claude

# --- dependencies/artifacts (installed/built inside the image) ---

node_modules
vendor
public/build
public/hot
public/storage

# --- runtime storage (created by the entrypoint / mounted as a volume) ---

storage/app/public/*
!storage/app/public/.gitkeep
storage/app/private/*
!storage/app/private/.gitkeep
storage/framework/cache/*
!storage/framework/cache/.gitkeep
storage/framework/sessions/*
!storage/framework/sessions/.gitkeep
storage/framework/views/*
!storage/framework/views/.gitkeep
storage/logs/*
!storage/logs/.gitkeep
bootstrap/cache/*
!bootstrap/cache/.gitkeep

# --- tests / linters (not needed in the prod image) ---

tests
phpunit.xml
.phpunit.result.cache
.editorconfig

# --- secrets / local env (not put into the image; .env is mounted/provided from outside) ---

.env
.env.*
!.env.example

# --- compose / docker meta-files (not part of the application code) ---

docker-compose.yml
docker-compose.override.yml
compose.dev.yaml
compose.*.yaml
.dockerignore

# --- DB files / documentation / design sources ---

*.sqlite
*.md
!README.md
figma
docs
design-system

# --- agent's internal instructions and audit reports (not needed in the prod image) ---

CLAUDE.md
audit

# --- Bot module ---

modules/max-bot/venv
modules/max-bot/__pycache__
modules/max-bot/.pytest_cache
modules/max-bot/.env
