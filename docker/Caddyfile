# =============================================================================
#  FrankenPHP / Caddy config for the Laravel Admin Template.
#
#  SERVER_NAME is set via the environment (default ":8000" from the Dockerfile).
#  Behind a reverse proxy (nginx/traefik) terminating TLS — we keep HTTP on :8000,
#  trustProxies is already configured in bootstrap/app.php.
#
#  Worker mode (optional, higher throughput): uncomment the `worker` line
#  and set FRANKENPHP_CONFIG="worker ./public/index.php" — but it keeps
#  state between requests and requires worker-compatible code. For the template it is
#  off by default (classic mode, safe for any Laravel application).
# =============================================================================

{
	# Disable the Caddy admin API — not needed in the container.
	admin off

	# The log level is controlled from outside; only the format here.
	frankenphp {
		# worker ./public/index.php
	}

	# Behind an external TLS proxy, Caddy's automatic HTTPS is not needed.
	auto_https off
}

{$SERVER_NAME:":8000"} {
	root * /app/public
	encode zstd br gzip

	# Uploaded media (/storage → symlink to storage/app/public) is served STRICTLY
	# as static: this handle never reaches php_server, so no file under
	# /storage is executed as PHP (defense-in-depth for S1 — even if a .php ends up
	# on disk). nosniff stops the browser from guessing the type (txt→html), and
	# Content-Disposition: attachment forces a download rather than rendering on
	# direct navigation (neutralizes stored-XSS from .html/.svg). It doesn't affect inline
	# images in the admin: the lightbox/preview load them via <img> (a subresource —
	# Content-Disposition is ignored), and non-images the UI opens/downloads anyway.
	@storage path /storage/*
	handle @storage {
		header X-Content-Type-Options nosniff
		header Content-Disposition attachment
		# A restrictive per-response CSP: even if the file does get rendered,
		# sandbox + default-src 'none' kill scripts/forms/plugins (S8 — a sandbox
		# for user content, complementing nosniff/attachment from S1).
		header Content-Security-Policy "default-src 'none'; sandbox"
		file_server
	}

	# The rest of the traffic: Laravel health check (/up), assets from public/build and the SPA —
	# through PHP.
	handle {
		php_server {
			# Before index.php, try to serve an existing file (assets from public/build).
			try_files {path} {path}/ /index.php?{query}
		}
	}

	log {
		output stderr
		format console
	}
}
