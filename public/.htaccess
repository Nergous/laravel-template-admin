<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Defense-in-depth for S1: uploaded media (/storage → symlink to
    # storage/app/public) is static and must not be executed as code. We forbid
    # direct access to any script extension under /storage (403), without relying
    # on a specific SAPI/handler. This must come BEFORE the front controller: that one passes
    # existing files (!-f) through, so a real /storage/x.php would otherwise reach PHP.
    RewriteRule ^storage/.*\.(?i:php[0-9]?|phar|phtml|phps|pht|cgi|pl|py|asp|aspx|jsp|sh)$ - [F]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Safe headers for served media (/storage): forbid MIME-sniffing and force a
# download instead of rendering — neutralizes stored-XSS from .html/.svg
# (S1). Apache serves /storage statically, bypassing Laravel, so the application's
# security headers don't reach here — we set them here. It doesn't affect inline images
# in the admin (loaded via <img>; for a subresource Content-Disposition is
# ignored).
<IfModule mod_headers.c>
    <If "%{REQUEST_URI} =~ m#^/storage/#">
        Header always set X-Content-Type-Options "nosniff"
        Header always set Content-Disposition "attachment"
        # A sandbox for user content (S8): kills scripts/forms,
        # even if the file does get rendered. Complements nosniff/attachment (S1).
        Header always set Content-Security-Policy "default-src 'none'; sandbox"
    </If>
</IfModule>
