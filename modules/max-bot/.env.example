# Used by pytest (loaded via python-dotenv in conftest.py)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bot-test-db
DB_USERNAME=root
DB_PASSWORD=

API_TOKEN=fake_test_token
API_BASE_URL=https://platform-api2.max.ru
BOT_ID=261592040

LOG_LEVEL_BOT=DEBUG

# Root of the Laravel public disk (storage/app/public) where media library files
# live. The bot reads files attached to messages from here and uploads them to MAX.
# In Docker this is set to /app/storage/app/public and the storage volume is mounted
# read-only (see docker-compose.yml). For a local run leave it empty — it defaults
# to the repo's storage/app/public.
# MEDIA_ROOT=
